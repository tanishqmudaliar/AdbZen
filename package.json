{
  "name": "adbzen",
  "displayName": "AdbZen",
  "description": "Manage ADB connections, pair Android devices wirelessly, and track device states directly from the VS Code sidebar.",
  "version": "0.0.1",
  "publisher": "tanishqmudaliar",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tanishqmudaliar/AdbZen.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "adbzen-sidebar",
          "title": "AdbZen",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "adbzen-sidebar": [
        {
          "type": "webview",
          "id": "adbzen.mainView",
          "name": "AdbZen",
          "icon": "media/icon.png"
        },
        {
          "type": "webview",
          "id": "adbzen.wirelessView",
          "name": "Wireless Pairing",
          "icon": "media/icon.png"
        },
        {
          "type": "webview",
          "id": "adbzen.shellView",
          "name": "Shell",
          "icon": "media/icon.png"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/qrcode": "^1.5.6",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "bonjour-service": "^1.4.1",
    "qrcode": "^1.5.4"
  }
}
