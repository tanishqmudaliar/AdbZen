{
  "name": "adbzen",
  "displayName": "AdbZen",
  "description": "ADB manager for VS Code",
  "version": "0.0.1",
  "publisher": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/tanishqmudaliar/AdbZen.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "adbzen-sidebar",
          "title": "AdbZen",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "adbzen-sidebar": [
        {
          "type": "webview",
          "id": "adbzen.mainView",
          "name": "AdbZen",
          "icon": "media/icon.svg"
        },
        {
          "type": "webview",
          "id": "adbzen.wirelessView",
          "name": "Wireless Pairing",
          "icon": "media/icon.svg"
        },
        {
          "type": "webview",
          "id": "adbzen.shellView",
          "name": "Shell",
          "icon": "media/icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/qrcode": "^1.5.6",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "bonjour-service": "^1.4.1",
    "qrcode": "^1.5.4"
  }
}
